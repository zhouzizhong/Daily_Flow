{
  "name": "daily-flow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply daily-flow-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply daily-flow-db --remote",
    "db:studio": "wrangler d1 studio daily-flow-db --local",
    "db:seed": "tsx src/lib/db/seed.ts",
    "cf:build": "next build",
    "cf:deploy": "wrangler pages deploy .next --project-name=daily-flow",
    "deploy": "npm run cf:build && npm run cf:deploy"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "better-auth": "^1.5.6",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^1.6.0",
    "nanoid": "^5.1.7",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wrangler": "^4.77.0"
  }
}
